<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SMT.Plugins.Mods.Mods">

    <Grid RowDefinitions="80,*,80" ColumnDefinitions="*">
        <Grid Grid.Row="0" BackgroundColor="#0E0E0E">
            <Label Text="Mods" 
                   TextColor="White" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ModContentGrid" Spacing="10" Padding="10"/>
        </ScrollView>

        <!-- Bottom Panel -->
        <Grid Grid.Row="2" BackgroundColor="#1E1E1E">
            <Button x:Name="ImportBtn" Text="Import Package (*.ykm)" 
                    HorizontalOptions="End" 
                    VerticalOptions="Center"
                    Margin="0,0,20,0"
                    Clicked="Button_Clicked"/>
        </Grid>

    </Grid>
</ContentView>