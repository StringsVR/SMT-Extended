<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SMT.Maui.MainPage"
             Shell.NavBarIsVisible="False">

    <Grid ColumnDefinitions="180,*">

        <!-- Sidebar -->
        <VerticalStackLayout x:Name="VerticalContent" BackgroundColor="#282828" Padding="10">
            <Label Text="SMT" TextColor="White" FontSize="26" FontFamily="Segoe UI" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Main Content -->
        <ContentView x:Name="MainContent" Grid.Column="1" BackgroundColor="#121212"/>
    </Grid>

</ContentPage>
